{
  "name": "engram",
  "version": "0.1.0",
  "description": "A local-first personal memory server that any MCP client plugs into, so your context follows you across apps instead of living inside one vendor.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "engram": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "memory",
    "local-first"
  ],
  "author": "Kalyan Gopalam",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "fastembed": "^2.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
